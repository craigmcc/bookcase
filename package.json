{
  "name": "@craigmcc/bookcase",
  "version": "1.0.0",
  "description": "Library management application (server and client)",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc --watch --preserveWatchOutput",
    "develop:dev": "concurrently \"npm:build\" \"npm:start:dev\"",
    "develop:prod": "concurrently \"npm:build\" \"npm:start:prod\"",
    "start:dev": "NODE_ENV=development nodemon dist/server.js",
    "start:prod": "NODE_ENV=production nodemon dist/server.js",
    "test": "NODE_ENV=test mocha -r ts-node/register test/**/*Test.ts",
    "tsc": "tsc"
  },
  "keywords": [
    "bootstrap",
    "express",
    "javascript",
    "node",
    "postgres",
    "sequelize",
    "typescript"
  ],
  "author": "craigmcc",
  "license": "Apache-2.0",
  "devDependencies": {
    "@types/bluebird": "^3.5.33",
    "@types/body-parser": "^1.19.0",
    "@types/chai": "^4.2.14",
    "@types/cors": "^2.8.8",
    "@types/express": "^4.17.9",
    "@types/mocha": "^8.2.0",
    "@types/morgan": "^1.9.2",
    "@types/node": "^14.14.11",
    "@types/sequelize": "^4.28.9",
    "@types/validator": "^13.1.1",
    "chai": "^4.2.0",
    "concurrently": "^5.3.0",
    "mocha": "^8.2.1",
    "nodemon": "^2.0.6",
    "sqlite3": "^5.0.0",
    "ts-node": "^9.1.1",
    "typescript": "^4.1.2"
  },
  "dependencies": {
    "body-parser": "^1.19.0",
    "cors": "^2.8.5",
    "csvtojson": "^2.0.10",
    "custom-env": "^2.0.1",
    "express": "^4.17.1",
    "morgan": "^1.10.0",
    "pg": "^8.5.1",
    "pg-hstore": "^2.3.3",
    "reflect-metadata": "^0.1.13",
    "sequelize": "^5.22.3",
    "sequelize-typescript": "^1.1.0"
  }
}
